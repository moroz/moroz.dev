---
import Layout from "@layouts/Layout.astro";
import { formatDateTime } from "@/lib/datetime.ts";
import { type BlogPost, PER_PAGE } from "@/lib/blog.ts";
import Pagination from "@components/Pagination.astro";

interface Props {
  posts: BlogPost[];
  page: number;
  totalPageCount: number;
  totalPostCount: number;
}

const { page, posts, totalPageCount, totalPostCount } = Astro.props;

const startIndex = (page - 1) * PER_PAGE + 1;
const endIndex = startIndex + posts.length - 1;
---

<Layout title="Blog">
  <div class="content mx-auto">
    <p>
      Displaying posts <strong>{startIndex}&ndash;{endIndex}</strong> out of <strong
        >{totalPostCount}</strong
      >.
    </p>
  </div>
  {
    posts.map((post) => (
      <article class="content mx-auto my-12">
        <a href={`/blog/${post.id}`} class="!no-underline">
          <h3 class="!text-primary hover:!text-primary-hover text-2xl font-bold transition-colors">
            {post.data.title}
          </h3>
        </a>
        <p class="content my-3!">{post.data.summary}</p>
        <span>
          <strong>Karol Moroz</strong> on
          <time datetime={post.data.date.toJSON()}>
            {formatDateTime(post.data.date)}
          </time>
        </span>
      </article>
    ))
  }
  <Pagination totalPages={totalPageCount} page={page} />
</Layout>
