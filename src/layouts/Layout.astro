---
import "../styles/global.css";
import Header from "@components/Header.svelte";
import Footer from "@components/Footer.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const defaultTitle = "moroz.dev";
const resolvedTitle = title ? `${title} | ${defaultTitle}` : defaultTitle;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
  </head>
  <body
    class="flex min-h-screen flex-col bg-white text-black dark:bg-slate-950 dark:text-gray-200"
  >
    <Header client:load />
    <main class="flex-1 py-16">
      <div class="mobile:px-4">
        <h2
          class="mt-6 mb-4 text-center text-2xl font-bold lg:mt-10 lg:text-4xl"
        >
          {title}
        </h2>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
